{
  "manifest_version": 3,
  "name": "SafeSite Checker",
  "version": "1.0",
  "description": "Checks if a website is safe",
  "permissions": ["tabs"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}