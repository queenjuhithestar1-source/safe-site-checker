{
  "manifest_version": 3,
  "name": "Buddy - SafeSite Checker",
  "version": "1.0",
  "description": "Your friendly cybersecurity buddy that checks website safety",
  "permissions": ["tabs"],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "logo.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}